// ─── Revision Planner ─────────────────────────────────────────────────────────

model RevisionExam {
  id           String   @id @default(cuid())
  studentId    String   // User.id
  subject      String
  examBoard    String?  // "AQA" | "Edexcel" | "OCR" | "WJEC" | "Other"
  paperName    String?  // e.g. "Paper 1: Living with the Physical Environment"
  examDate     DateTime
  durationMins Int?
  createdAt    DateTime @default(now())

  sessions RevisionSession[]

  @@index([studentId])
}

model RevisionSession {
  id            String   @id @default(cuid())
  studentId     String   // User.id
  examId        String?  // RevisionExam.id — optional link
  subject       String
  topic         String
  scheduledAt   DateTime // Date + time slot
  durationMins  Int      @default(45)
  status        String   @default("planned") // "planned" | "completed" | "skipped"
  confidence    Int?     // 1–5 self-assessment after completing
  notes         String?
  oakLessonSlug String?  // Optional link to an OakLesson
  createdAt     DateTime @default(now())

  exam RevisionExam? @relation(fields: [examId], references: [id])

  @@index([studentId])
  @@index([scheduledAt])
}

model RevisionConfidence {
  id         String   @id @default(cuid())
  studentId  String   // User.id
  subject    String
  topic      String
  confidence Int      // 1–5 (1=not at all confident, 5=very confident)
  assessedAt DateTime @default(now())

  @@index([studentId, subject])
}

// ─── Accessibility Settings ───────────────────────────────────────────────────

model UserAccessibilitySettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  dyslexiaFont  Boolean  @default(false)
  highContrast  Boolean  @default(false)
  largeText     Boolean  @default(false)
  reducedMotion Boolean  @default(false)
  lineSpacing   String   @default("normal") // "normal" | "wide" | "wider"
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Phase 5 — SEND Monitoring & Early Warning ───────────────────────────────

model SendConcern {
  id            String    @id @default(cuid())
  schoolId      String
  studentId     String
  raisedBy      String
  source        String    // "teacher" | "system" | "parent" | "self"
  category      String    // "literacy" | "numeracy" | "behaviour" | "attendance"
                          // | "social_emotional" | "communication" | "physical" | "sensory" | "other"
  description   String
  evidenceNotes String?
  status        String    @default("open")
                          // "open" | "under_review" | "escalated" | "monitoring" | "closed" | "no_action"
  aiAnalysis    String?
  createdAt     DateTime  @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?

  school          School             @relation(fields: [schoolId], references: [id])
  student         User               @relation("StudentConcerns", fields: [studentId], references: [id])
  raisedByUser    User               @relation("RaisedConcerns", fields: [raisedBy], references: [id])
  reviewedByUser  User?              @relation("ReviewedConcerns", fields: [reviewedBy], references: [id])
  notifications   SendNotification[]

  @@index([schoolId, studentId])
  @@index([schoolId, status])
}

model IndividualLearningPlan {
  id               String      @id @default(cuid())
  schoolId         String
  studentId        String
  createdBy        String
  sendCategory     String
  currentStrengths String
  areasOfNeed      String
  strategies       String[]
  successCriteria  String
  reviewDate       DateTime
  status           String      @default("active") // "active" | "under_review" | "archived"
  parentConsent    Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  school   School      @relation("SchoolLearningPlans", fields: [schoolId], references: [id])
  student  User        @relation("StudentIlps", fields: [studentId], references: [id])
  creator  User        @relation("IlpCreator", fields: [createdBy], references: [id])
  targets  IlpTarget[]

  @@index([schoolId, studentId])
}

model IlpTarget {
  id              String    @id @default(cuid())
  ilpId           String
  target          String
  strategy        String
  successMeasure  String
  targetDate      DateTime
  status          String    @default("active") // "active" | "achieved" | "not_achieved" | "deferred"
  progressNotes   String?
  reviewedAt      DateTime?

  ilp IndividualLearningPlan @relation(fields: [ilpId], references: [id], onDelete: Cascade)

  @@index([ilpId])
}

model SendNotification {
  id          String    @id @default(cuid())
  schoolId    String
  recipientId String
  concernId   String?
  type        String    // "new_concern" | "concern_escalated" | "ilp_created"
                        // | "ilp_review_due" | "pattern_detected" | "review_requested"
  title       String
  body        String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  school    School       @relation(fields: [schoolId], references: [id])
  recipient User         @relation("NotificationRecipient", fields: [recipientId], references: [id])
  concern   SendConcern? @relation(fields: [concernId], references: [id])

  @@index([recipientId, isRead])
  @@index([schoolId])
}

model SendReviewLog {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  action    String   // "concern_raised" | "concern_reviewed" | "ilp_created"
                     // | "ilp_updated" | "ilp_reviewed" | "concern_closed"
  actorId   String
  metadata  Json?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  actor  User   @relation("SendActor", fields: [actorId], references: [id])

  @@index([schoolId, studentId])
}

model EarlyWarningFlag {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  flagType    String    // "homework_decline" | "completion_drop" | "score_decline"
                        // | "pattern_absence" | "multiple_concerns"
  severity    String    // "low" | "medium" | "high"
  description String
  dataPoints  Json
  isActioned  Boolean   @default(false)
  actionedBy  String?
  actionedAt  DateTime?
  actionNotes String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  school     School @relation(fields: [schoolId], references: [id])
  actionedByUser User? @relation("FlagActioner", fields: [actionedBy], references: [id])

  @@index([schoolId, isActioned])
  @@index([studentId])
}

// ─── Phase 6 — Adaptive Learning & EHCP ──────────────────────────────────────

model LearningSequence {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String
  subject     String
  topic       String
  createdBy   String
  homeworkIds String[]
  spacingDays Int[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  school School      @relation(fields: [schoolId], references: [id])
  class  SchoolClass @relation(fields: [classId], references: [id])

  @@index([schoolId, classId])
}

model StudentLearningProfile {
  id                 String    @id @default(cuid())
  studentId          String    @unique
  schoolId           String
  typePerformance    Json      @default("{}")
  bloomsPerformance  Json      @default("{}")
  subjectPerformance Json      @default("{}")
  preferredTypes     String[]
  strengthAreas      String[]
  developmentAreas   String[]
  avgCompletionRate  Float     @default(0)
  avgTimeAccuracy    Float     @default(0)
  profileSummary     String?
  profileUpdatedAt   DateTime?
  updatedAt          DateTime  @updatedAt

  student User   @relation(fields: [studentId], references: [id])
  school  School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model EhcpPlan {
  id              String      @id @default(cuid())
  schoolId        String
  studentId       String
  localAuthority  String
  planDate        DateTime
  reviewDate      DateTime
  coordinatorName String?
  status          String      @default("active") // "active" | "under_review" | "ceased"
  createdBy       String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  school   School        @relation(fields: [schoolId], references: [id])
  student  User          @relation("StudentEhcps", fields: [studentId], references: [id])
  creator  User          @relation("EhcpCreator", fields: [createdBy], references: [id])
  outcomes EhcpOutcome[]

  @@index([schoolId, studentId])
}

model EhcpOutcome {
  id                String   @id @default(cuid())
  ehcpId            String
  section           String   // "A" | "B" | "C" | "D" | "E" | "F" | "G" | "H1" | "H2" | "I" | "J" | "K"
  outcomeText       String
  targetDate        DateTime
  successCriteria   String
  provisionRequired String?
  status            String   @default("active") // "active" | "achieved" | "partially_achieved" | "not_achieved"
  evidenceCount     Int      @default(0)

  ehcp     EhcpPlan              @relation(fields: [ehcpId], references: [id])
  evidence HomeworkEhcpEvidence[]

  @@index([ehcpId])
}

model HomeworkEhcpEvidence {
  id            String    @id @default(cuid())
  outcomeId     String
  submissionId  String
  teacherNote   String?
  evidenceDate  DateTime  @default(now())
  qualityRating Int?

  outcome    EhcpOutcome @relation(fields: [outcomeId], references: [id])
  submission Submission  @relation(fields: [submissionId], references: [id])

  @@index([outcomeId])
  @@index([submissionId])
}

model IlpHomeworkLink {
  id           String   @id @default(cuid())
  ilpTargetId  String
  homeworkId   String
  linkedBy     String
  linkedAt     DateTime @default(now())
  evidenceNote String?

  homework Homework @relation(fields: [homeworkId], references: [id])
  linkedByUser User @relation(fields: [linkedBy], references: [id])

  @@unique([ilpTargetId, homeworkId])
  @@index([homeworkId])
  @@index([ilpTargetId])
}
