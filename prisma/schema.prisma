// ─── Cover Management ─────────────────────────────────────────────────────────

model StaffAbsence {
  id               String            @id @default(cuid())
  school           School            @relation(fields: [schoolId], references: [id])
  schoolId         String
  staffId          String            // WondeEmployee.id
  date             DateTime          // Date of absence
  reason           String            // "illness" | "training" | "personal" | "other"
  notes            String?
  reportedBy       String            // User.id of admin who logged it
