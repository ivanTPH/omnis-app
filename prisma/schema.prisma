  allowSmsNotifications      Boolean @default(false)
  allowAnalyticsInsights     Boolean @default(true)
  profileVisibleToColleagues Boolean @default(true)
  profileVisibleToAdmins     Boolean @default(true)

  // Lesson Sharing & AI
  lessonSharing      LessonSharingLevel @default(PRIVATE)
  allowAiImprovement Boolean            @default(false)

  // Pending email change (stored until verified)
  pendingEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── School Calendar ─────────────────────────────────────────────────────────

model SchoolCalendar {
  id       String   @id @default(cuid())
  school   School   @relation(fields: [schoolId], references: [id])
  schoolId String
  date     DateTime
  type     String   // HOLIDAY | INSET | TERM_START | TERM_END | EVENT
  label    String?
  createdAt DateTime @default(now())

  @@index([schoolId, date])
