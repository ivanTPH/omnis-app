// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  userId    String
  type      String   // HOMEWORK_SUBMITTED | PLAN_REVIEW_DUE | SUBMISSION_FLAGGED | HOMEWORK_GRADED | GENERAL
  title     String
  body      String
  read      Boolean  @default(false)
  linkHref  String?
  createdAt DateTime @default(now())

  @@index([schoolId, userId, read])
  @@index([schoolId, userId, createdAt])
}

// ─── Audit log (immutable) ────────────────────────────────────────────────────

model AuditLog {
