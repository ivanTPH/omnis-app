  status           String       @default("unassigned") // "unassigned" | "assigned" | "confirmed" | "cancelled"
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  absence          StaffAbsence @relation(fields: [absenceId], references: [id], onDelete: Cascade)

  @@index([schoolId, absenceId])
  @@index([coveredBy])
