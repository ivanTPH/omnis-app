{
  "name": "omnis-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx prisma db seed",
    "db:seed:ci": "tsx scripts/ci-seed.ts",
    "db:seed-classes": "tsx --env-file=.env.local prisma/seed-classes.ts",
    "db:seed-english": "tsx --env-file=.env.local prisma/seed-english-students.ts",
    "oak:sync": "tsx --env-file=.env.local scripts/oak-sync.ts",
    "oak:delta": "tsx --env-file=.env.local scripts/oak-delta-sync.ts",
    "wonde:seed": "tsx --env-file=.env.local prisma/seed-wonde.ts",
    "platform:seed": "tsx --env-file=.env.local prisma/seed-platform.ts",
    "academy:seed": "tsx --env-file=.env.local prisma/seed-academy.ts",
    "send:seed": "tsx --env-file=.env.local prisma/seed-send.ts",
    "messages:seed": "tsx --env-file=.env.local prisma/seed-messages.ts",
    "ta:seed": "tsx --env-file=.env.local prisma/seed-ta-notes.ts",
    "agents:seed": "tsx --env-file=.env.local prisma/seed-agent-snapshots.ts",
    "grade:seed": "tsx --env-file=.env.local prisma/seed-graded.ts",
    "revision:seed": "tsx --env-file=.env.local prisma/seed-revision.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "topup:seed": "tsx --env-file=.env.local prisma/seed-topup.ts",
    "humanities:seed": "tsx --env-file=.env.local prisma/seed-humanities.ts",
    "send:backfill-snapshots": "tsx --env-file=.env.local scripts/backfill-send-snapshots.ts",
    "demo:reset": "tsx --env-file=.env.local scripts/demo-reset.ts",
    "demo:seed": "tsx --env-file=.env.local prisma/seed-demo.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.57.0",
    "@sparticuz/chromium": "^149.0.0",
    "@types/marked": "^5.0.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.4",
    "material-icons": "^1.13.14",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^6.19.2",
    "puppeteer": "^24.38.0",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx --env-file=.env.local prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=200"
    ]
  }
}
