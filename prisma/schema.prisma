// ─── SEND Score Cache ─────────────────────────────────────────────────────────

model SendScoreCache {
  id          String   @id @default(cuid())
  contentHash String   @unique
  score       Int
  suggestions Json     @default("[]")
  hitCount    Int      @default(1)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
}

// ─── Oak National Academy Content Library ─────────────────────────────────────
//
// Global (not school-scoped) — shared content library synced from Oak's API.
// OakSubject → OakUnit → OakLesson → OakResource
//
// Categorisation fields use plain strings (not enums) to match Oak's slug
// conventions directly: keystage "ks1"–"ks4", phase "primary"/"secondary",
// examBoard "aqa"/"edexcel"/etc., tier "foundation"/"higher".

model OakSubject {
  slug      String   @id          // "english" | "maths" | "history" …
  title     String                // "English" | "Maths" | "History" …
  phase     String                // "primary" | "secondary"
  syncedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastSeenAt DateTime? // Updated every delta sync run
  deletedAt  DateTime? // Set when subject no longer seen in Oak API

  units OakUnit[]

  @@index([phase])
}

model OakUnit {
  slug        String @id           // "modern-text-first-study-4896"
  title       String
  subjectSlug String
  subject     OakSubject @relation(fields: [subjectSlug], references: [slug])

  // Categorisation
  keystage      String   // "ks1" | "ks2" | "ks3" | "ks4"
  yearGroup     Int?     // null when a unit spans multiple years
  examBoard     String?  // "aqa" | "edexcel" | "ocr" | "wjec" | null
  tier          String?  // "foundation" | "higher" | null
  programmeSlug String   // full slug e.g. "english-secondary-ks4-aqa"

  // Curriculum detail
  description                String?
  whyThisWhyNow              String?
  priorKnowledgeRequirements Json    @default("[]")
  nationalCurriculumContent  Json    @default("[]")
  threads                    Json    @default("[]") // learning strands [{title,slug,order}]
  subjectCategories          Json    @default("[]") // e.g. [{label:"Literature",slug:"literature"}]

  // Sequencing
  connectionPriorUnit  String?
  connectionFutureUnit String?

  plannedLessonCount Int     @default(0)
  orderInProgramme   Int     @default(0)
  isLegacy           Boolean @default(false)

  syncedAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime? // Updated every delta sync run
  deletedAt  DateTime? // Set when unit no longer seen in Oak API

  lessons OakLesson[]

  @@index([subjectSlug])
  @@index([keystage])
  @@index([programmeSlug])
  @@index([examBoard])
  @@index([yearGroup])
}

model OakLesson {
  slug        String   @id          // "understanding-context-and-priestleys-influences-65k3gd"
  title       String
  unitSlug    String
  unit        OakUnit  @relation(fields: [unitSlug], references: [slug])

  // Denormalised for fast filtering without joins
  subjectSlug String
  keystage    String
  yearGroup   Int?
  examBoard   String?
  tier        String?
  orderInUnit Int @default(0)

  // Learning content
  pupilLessonOutcome String?
  keyLearningPoints  Json   @default("[]") // [{keyLearningPoint: "..."}]
  lessonKeywords     Json   @default("[]") // [{keyword:"...",description:"..."}]
  lessonOutline      Json   @default("[]") // [{lessonOutline:"..."}]

  // Quizzes — full structured data (questionStem, answers, feedback, hint)
  starterQuiz Json @default("[]")
  exitQuiz    Json @default("[]")

  // Teacher support
  misconceptionsAndCommonMistakes Json    @default("[]")
  teacherTips                     Json    @default("[]")
  contentGuidance                 Json    @default("[]")
  supervisionLevel                String?

  // Media
  videoMuxPlaybackId                 String?
  videoWithSignLanguageMuxPlaybackId String?
  transcriptSentences                Json    @default("[]")

  // Downloadable materials (Google Slides source URLs)
  worksheetUrl    String?
  presentationUrl String?

  // Categorisation
  subjectCategories Json @default("[]")

  isLegacy      Boolean @default(false)
  expired       Boolean @default(false)
  loginRequired Boolean @default(false)

  syncedAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime? // Updated every delta sync run
  deletedAt  DateTime? // Set when lesson no longer seen in Oak API

  resources        OakResource[]
  sendQualityScore SendQualityScore?

  @@index([unitSlug])
  @@index([subjectSlug])
  @@index([keystage])
  @@index([examBoard])
  @@index([yearGroup])
}

model OakSyncLog {
  id         String    @id @default(cuid())
  type       String    @default("delta") // "full" | "delta"
  status     String    @default("running") // "running" | "completed" | "failed" | "partial"
  startedAt  DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  // Delta counts
  newSubjects     Int @default(0)
  updatedSubjects Int @default(0)
  deletedSubjects Int @default(0)
  newUnits        Int @default(0)
  updatedUnits    Int @default(0)
  deletedUnits    Int @default(0)
  newLessons      Int @default(0)
  updatedLessons  Int @default(0)
  deletedLessons  Int @default(0)
  errorCount      Int @default(0)
  errors          Json @default("[]") // [{slug, message}]

  @@index([startedAt])
}

model SendQualityScore {
  id               String    @id @default(cuid())
  oakLessonSlug    String    @unique
  lesson           OakLesson @relation(fields: [oakLessonSlug], references: [slug])
  overallScore     Int
  readabilityScore Int
  visualLoadScore  Int
  cognitiveScore   Int
  languageScore    Int
  structureScore   Int
  summary          String
  recommendations  String[]
  scoredAt         DateTime  @default(now())
  modelVersion     String    @default("claude-sonnet-4-20250514")
}

model OakResource {
  id         String    @id @default(cuid())
  lessonSlug String
  lesson     OakLesson @relation(fields: [lessonSlug], references: [slug])

  // Type matches Oak's download type strings exactly
  type   String  // "presentation" | "worksheet-pdf" | "worksheet-pptx"
                 // "intro-quiz-questions" | "intro-quiz-answers"
                 // "exit-quiz-questions"  | "exit-quiz-answers"
                 // "supplementary-pdf"    | "lesson-guide-pdf"
  label  String? // "Lesson slides" | "Starter quiz questions" …
  ext    String? // "pptx" | "pdf"
  exists Boolean @default(true)

  @@unique([lessonSlug, type])
  @@index([lessonSlug])
}

// ─── SEND Insights (aggregated per school/subject/yearGroup/type) ─────────────

model SendInsight {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  subject        String
  yearGroup      Int
  resourceType   String
  avgScore       Float
  minScore       Int
  maxScore       Int
  totalResources Int
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([schoolId, subject, yearGroup, resourceType])
  @@index([schoolId])
}

// ─── GDPR Consent Management ──────────────────────────────────────────────────

model ConsentPurpose {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  slug        String   // e.g. "send-data-sharing", "photo-consent"
  title       String
  description String
  lawfulBasis String   // "consent" | "legitimate_interest" | "legal_obligation"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  records     ConsentRecord[]

  @@unique([schoolId, slug])
  @@index([schoolId])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  purposeId   String
  studentId   String   // WondeStudent.id
  responderId String   // User.id (parent or guardian)
  decision    String   // "granted" | "withdrawn"
  method      String   // "portal" | "paper" | "verbal" | "imported"
  notes       String?
  recordedAt  DateTime @default(now())
  expiresAt   DateTime?

  purpose  ConsentPurpose @relation(fields: [purposeId], references: [id])

  @@index([purposeId])
  @@index([studentId])
  @@index([responderId])
}

model DataSubjectRequest {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  requestType String   // "access" | "erasure" | "rectification" | "portability"
  studentId   String?
  submittedBy String   // User.id
  status      String   @default("pending") // "pending" | "in_progress" | "completed" | "rejected"
  notes       String?
  submittedAt DateTime @default(now())
  resolvedAt  DateTime?

  @@index([schoolId, status])
}

// ─── Platform Admin ───────────────────────────────────────────────────────────

model SchoolFeatureFlag {
  id       String   @id @default(cuid())
  schoolId String
  flag     String   // "send_scorer" | "oak_resources" | "gdpr_portal" | "parent_portal" | "wonde_sync"
  enabled  Boolean  @default(true)
  setAt    DateTime @default(now())
  setBy    String   // User.id of platform admin who set it

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, flag])
}

model PlatformAuditLog {
  id        String   @id @default(cuid())
  actorId   String   // User.id
  action    String   // e.g. "school.created", "flag.toggled", "school.deactivated"
  target    String?  // schoolId or other entity id
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

// ─── AI Resource Generator ────────────────────────────────────────────────────

model GeneratedResource {
  id             String   @id @default(cuid())
  schoolId       String
  createdBy      String   // User.id
  title          String
  subject        String
  yearGroup      String
  resourceType   String   // "worksheet" | "quiz" | "lesson_plan" | "exit_ticket" | "knowledge_organiser"
  topic          String
  content        String   @db.Text
  sendAdapted    Boolean  @default(false)
  sendNotes      String?
  modelVersion   String   @default("claude-sonnet-4-20250514")
  createdAt      DateTime @default(now())
  linkedLessonId String?

